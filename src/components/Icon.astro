---

interface Props {
	height?: number,
	width?: number,
}

const { height = 36, width = 36 } = Astro.props;

---

<svg xmlns="http://www.w3.org/2000/svg" width={width} height={height} viewBox="0 0 36 36" transform="scale(1)">
	<!-- yeah this is horrible but it works -->
	<g transform="translate(-32 -32) translate(18 18)">
		<!-- eyes -->
		<ellipse rx="4.132947" ry="4.47" cx="30.3" cy="34.35" transform="skewX(-10)" />
		<ellipse rx="4.132947" ry="4.47" cx="33.7" cy="34.35" transform="skewX(10)" />
		<!-- noise -->
		<ellipse rx="2.3" ry="1.07" cx="32" cy="38.57" />
		<!-- cheeks -->
		<ellipse rx="2.08" ry="1.03" cx="42.19" cy="39.922" fill="#ff86c3" fill-opacity="0.4" />
		<ellipse rx="2.08" ry="1.03" cx="21.81" cy="39.922" fill="#ff86c3" fill-opacity="0.4" />
		<!-- puplis -->
		<circle r="1.17" cx="38.22" cy="32.74" fill="white" />
		<circle r="1.17" cx="25.78" cy="32.74" fill="white" />
		<!-- ears -->
		<path d="M16.08 26.9C12.17 22.83 20.45 15.94 23.767 20.475 22.07 21.36 21.17 21.72 19.32 23.16 18.5 23.91 16.82 25.51 16.08 26.9" />
		<path d="M16.08 26.9C12.17 22.83 20.45 15.94 23.767 20.475 22.07 21.36 21.17 21.72 19.32 23.16 18.5 23.91 16.82 25.51 16.08 26.9" transform="translate(64.32 0) scale(-1 1)" />
		<!-- mouth -->
		<path d="M27.94 40.88A1 1 0 0 0 32.06 39.35L31.56 39.6A1 1 0 0 1 28.29 40.59" />
		<path d="M27.94 40.88A1 1 0 0 0 32.06 39.35L31.56 39.6A1 1 0 0 1 28.29 40.59" transform="translate(64 0) scale(-1 1)" />
	</g>
</svg>

